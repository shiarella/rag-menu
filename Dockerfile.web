FROM node:20-alpine AS builder

WORKDIR /app

COPY frontend-v2/package*.json ./
RUN npm ci

COPY frontend-v2/ .

# At build time: tell Next.js where the API lives.
# In production the Next.js rewrite proxies /api/* → the api container,
# so NEXT_PUBLIC_API is just "/api" — no hostname needed in the browser.
ARG NEXT_PUBLIC_API=/api
ENV NEXT_PUBLIC_API=$NEXT_PUBLIC_API

RUN npm run build

# ── Runtime stage ─────────────────────────────────────────────────────────────
FROM node:20-alpine AS runner

WORKDIR /app
ENV NODE_ENV=production

COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

CMD ["node", "server.js"]
